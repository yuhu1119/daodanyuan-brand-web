# 管理后台配置（复制为 .env 后修改，切勿将 .env 提交到版本库）

# 服务端口
ADMIN_PORT=3000

# 管理员账号（生产环境必须修改）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请设置强密码

# 会话密钥（生产环境必须设置随机长字符串，否则重启后会话失效）
SESSION_SECRET=请替换为随机长字符串

# HTTPS 部署时设为 true
# COOKIE_SECURE=true

# 生产环境
NODE_ENV=production

# 构建 sitemap 时使用的站点根 URL（可选）
# SITE_URL=https://www.daodanyuan.com
